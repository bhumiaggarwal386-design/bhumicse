<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/layout_category"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F8F7FF">
    <!-- HEADER -->
    <include layout="@layout/header"/>
    <!-- Top Bar -->
    <LinearLayout
        android:id="@+id/layout_cat_topbar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:background="#FFFFFF">

        <ImageView
            android:id="@+id/btn_cat_back"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_arrow_back"
            android:contentDescription="Back"
            android:layout_marginEnd="12dp"
            android:padding="4dp" />

        <TextView
            android:id="@+id/tv_category_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Topwear"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#4A4A6A" />

    </LinearLayout>

    <!-- Search Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="14dp"
        android:paddingBottom="4dp">

        <EditText
            android:id="@+id/et_search"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="Search items..."
            android:textSize="13sp"
            android:textColor="#4A4A6A"
            android:textColorHint="#C5C1FF"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:background="@drawable/bg_search_bar"
            android:imeOptions="actionSearch"
            android:inputType="text"
            android:singleLine="true" />

    </LinearLayout>

    <!-- Item count -->
    <TextView
        android:id="@+id/tv_item_count"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="10dp"
        android:paddingBottom="6dp"
        android:text="24 items"
        android:textSize="12sp"
        android:textColor="#C5C1FF" />

    <!-- Category Items Grid -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_category_items"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:paddingBottom="10dp"
        android:scrollbars="none" />

</LinearLayout>