<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/layout_editor"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F8F7FF">

    <!-- HEADER -->
    <include layout="@layout/header"/>

    <!-- Top Bar -->
    <LinearLayout
        android:id="@+id/layout_topbar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:background="#FFFFFF">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_arrow_back"
            android:contentDescription="Back"
            android:layout_marginEnd="12dp"
            android:padding="4dp" />

        <TextView
            android:id="@+id/tv_editor_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Edit Outfit"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#4A4A6A" />

        <Button
            android:id="@+id/btn_save"
            android:layout_width="72dp"
            android:layout_height="48dp"
            android:text="Save"
            android:textSize="13sp"
            android:textColor="#FFFFFF"
            android:background="@drawable/bg_btn_primary"
            android:stateListAnimator="@null"
            android:elevation="0dp" />

    </LinearLayout>

    <!-- Canvas -->
    <FrameLayout
        android:id="@+id/frame_canvas_wrapper"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="16dp">

        <androidx.cardview.widget.CardView
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:id="@+id/card_canvas"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#FFFFFF">

            <FrameLayout
                android:id="@+id/layout_canvas"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#FFFFFF">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_canvas_border" />

                <TextView
                    android:id="@+id/tv_canvas_hint"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="Tap a category below&#10;to add items"
                    android:textSize="14sp"
                    android:textColor="#C5C1FF"
                    android:gravity="center"
                    android:lineSpacingExtra="4dp" />

            </FrameLayout>

        </androidx.cardview.widget.CardView>

    </FrameLayout>

    <!-- Bottom Category Buttons -->
    <LinearLayout
        android:id="@+id/layout_category_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#FFFFFF"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="10dp"
        android:paddingBottom="14dp"
        android:gravity="center_vertical">

        <Button
            android:id="@+id/btn_topwear"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginEnd="5dp"
            android:text="Topwear"
            android:textSize="11sp"
            android:textColor="#6C63FF"
            android:background="@drawable/bg_btn_category"
            android:stateListAnimator="@null"
            android:elevation="0dp" />

        <Button
            android:id="@+id/btn_bottomwear"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginEnd="5dp"
            android:text="Bottomwear"
            android:textSize="11sp"
            android:textColor="#6C63FF"
            android:background="@drawable/bg_btn_category"
            android:stateListAnimator="@null"
            android:elevation="0dp" />

        <!-- ✅ Shoes REMOVED -->

        <Button
            android:id="@+id/btn_accessories"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="Accessories"
            android:textSize="11sp"
            android:textColor="#6C63FF"
            android:background="@drawable/bg_btn_category"
            android:stateListAnimator="@null"
            android:elevation="0dp" />

    </LinearLayout>

</LinearLayout>