<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/card_outfit"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="6dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/img_outfit"
            android:layout_width="match_parent"
            android:layout_height="150dp"
            android:scaleType="centerCrop"
            android:contentDescription="Outfit image"
            android:background="#EDEBFF" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="10dp">

            <TextView
                android:id="@+id/tv_outfit_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Outfit Name"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#4A4A6A"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_marginBottom="4dp" />

            <RatingBar
                android:id="@+id/rating_outfit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:numStars="5"
                android:rating="3"
                android:stepSize="1"
                android:scaleX="0.7"
                android:scaleY="0.7"
                android:transformPivotX="0dp"
                android:layout_marginStart="-4dp"
                android:layout_marginBottom="6dp"
                style="@style/Widget.AppCompat.RatingBar.Small" />

            <Button
                android:id="@+id/btn_edit_outfit"
                android:layout_width="match_parent"
                android:layout_height="34dp"
                android:text="Edit"
                android:textSize="12sp"
                android:textColor="#6C63FF"
                android:background="@drawable/bg_btn_outline"
                android:stateListAnimator="@null"
                android:elevation="0dp" />

        </LinearLayout>
    </LinearLayout>

</androidx.cardview.widget.CardView>